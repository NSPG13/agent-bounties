{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agentbounties.org/schemas/discovery-manifest.v1.json",
  "title": "Agent Bounties Discovery Manifest",
  "description": "Machine-readable discovery contract for Agent Bounties API, MCP, payment, proof, risk, and template surfaces.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "name",
    "version",
    "description",
    "open_source",
    "endpoints",
    "agent_entrypoints",
    "payment_rails",
    "trust_tiers",
    "templates",
    "proof_surfaces",
    "risk_controls",
    "real_money_rehearsal",
    "distribution_feedback",
    "risk_policy"
  ],
  "properties": {
    "schema": {
      "type": "string",
      "format": "uri",
      "const": "https://agentbounties.org/schemas/discovery-manifest.v1.json"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "open_source": {
      "type": "boolean",
      "const": true
    },
    "endpoints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "api_base",
        "openapi_json",
        "swagger_ui",
        "mcp_tools",
        "discovery",
        "discovery_schema",
        "llms_txt",
        "agent_quickstart",
        "public_bounties",
        "public_bounty",
        "public_funding",
        "templates",
        "pooled_bounties",
        "bounty_funding_intents",
        "bounty_funding_contributions",
        "bounty_feed",
        "funding_feed",
        "capability_feed",
        "eval_runs",
        "risk_policy",
        "risk_events",
        "risk_reviews",
        "risk_bounty_approvals",
        "risk_payout_approvals",
        "risk_event_rejections",
        "agent_paid_status",
        "base_log_query",
        "base_escrow_events",
        "base_rpc_logs",
        "base_fetch_rpc_logs",
        "base_broadcast_signed_transaction",
        "base_transaction_receipt",
        "base_funding_plan",
        "base_release_queue",
        "base_refund_plan",
        "base_dispute_plan",
        "stripe_checkout_top_ups",
        "stripe_connect_accounts",
        "stripe_connect_transfers",
        "stripe_connect_snapshots",
        "stripe_live_checkout_top_ups",
        "stripe_live_connect_accounts",
        "stripe_live_connect_transfers",
        "stripe_transfer_events",
        "github_issue_bounty_plan",
        "github_funding_comment_plan",
        "github_proof_comment_plan",
        "github_proof_comment_from_proof_plan",
        "github_issue_template"
      ],
      "properties": {
        "api_base": { "$ref": "#/$defs/uri" },
        "openapi_json": { "$ref": "#/$defs/uri" },
        "swagger_ui": { "$ref": "#/$defs/uri" },
        "mcp_tools": { "$ref": "#/$defs/uri" },
        "discovery": { "$ref": "#/$defs/uri" },
        "discovery_schema": { "$ref": "#/$defs/uri" },
        "llms_txt": { "$ref": "#/$defs/uri" },
        "agent_quickstart": { "$ref": "#/$defs/uri" },
        "public_bounties": { "$ref": "#/$defs/uri" },
        "public_bounty": { "$ref": "#/$defs/uri-template" },
        "public_funding": { "$ref": "#/$defs/uri" },
        "templates": { "$ref": "#/$defs/uri" },
        "pooled_bounties": { "$ref": "#/$defs/uri" },
        "bounty_funding_intents": { "$ref": "#/$defs/uri-template" },
        "bounty_funding_contributions": { "$ref": "#/$defs/uri-template" },
        "bounty_feed": { "$ref": "#/$defs/uri" },
        "funding_feed": { "$ref": "#/$defs/uri" },
        "capability_feed": { "$ref": "#/$defs/uri" },
        "eval_runs": { "$ref": "#/$defs/uri" },
        "risk_policy": { "$ref": "#/$defs/uri" },
        "risk_events": { "$ref": "#/$defs/uri" },
        "risk_reviews": { "$ref": "#/$defs/uri" },
        "risk_bounty_approvals": { "$ref": "#/$defs/uri" },
        "risk_payout_approvals": { "$ref": "#/$defs/uri" },
        "risk_event_rejections": { "$ref": "#/$defs/uri-template" },
        "agent_paid_status": { "$ref": "#/$defs/uri-template" },
        "base_log_query": { "$ref": "#/$defs/uri" },
        "base_escrow_events": { "$ref": "#/$defs/uri" },
        "base_rpc_logs": { "$ref": "#/$defs/uri" },
        "base_fetch_rpc_logs": { "$ref": "#/$defs/uri" },
        "base_broadcast_signed_transaction": { "$ref": "#/$defs/uri" },
        "base_transaction_receipt": { "$ref": "#/$defs/uri" },
        "base_funding_plan": { "$ref": "#/$defs/uri" },
        "base_release_queue": { "$ref": "#/$defs/uri" },
        "base_refund_plan": { "$ref": "#/$defs/uri" },
        "base_dispute_plan": { "$ref": "#/$defs/uri" },
        "stripe_checkout_top_ups": { "$ref": "#/$defs/uri" },
        "stripe_connect_accounts": { "$ref": "#/$defs/uri" },
        "stripe_connect_transfers": { "$ref": "#/$defs/uri" },
        "stripe_connect_snapshots": { "$ref": "#/$defs/uri" },
        "stripe_live_checkout_top_ups": { "$ref": "#/$defs/uri" },
        "stripe_live_connect_accounts": { "$ref": "#/$defs/uri" },
        "stripe_live_connect_transfers": { "$ref": "#/$defs/uri" },
        "stripe_transfer_events": { "$ref": "#/$defs/uri" },
        "github_issue_bounty_plan": { "$ref": "#/$defs/uri" },
        "github_funding_comment_plan": { "$ref": "#/$defs/uri" },
        "github_proof_comment_plan": { "$ref": "#/$defs/uri" },
        "github_proof_comment_from_proof_plan": { "$ref": "#/$defs/uri" },
        "github_issue_template": { "$ref": "#/$defs/uri" }
      }
    },
    "agent_entrypoints": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/agent_entrypoint" }
    },
    "payment_rails": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/payment_rail" }
    },
    "trust_tiers": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/trust_tier" }
    },
    "templates": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/template" }
    },
    "proof_surfaces": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/uri-template" }
    },
    "risk_controls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "real_money_rehearsal": { "$ref": "#/$defs/real_money_rehearsal" },
    "distribution_feedback": { "$ref": "#/$defs/distribution_feedback" },
    "risk_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "version",
        "low_value_usdc_cap_minor",
        "low_value_usdc_cap_currency",
        "max_artifact_body_bytes",
        "min_clarity_chars",
        "banned_terms",
        "automatic_review_rules",
        "blocked_rules",
        "settlement_invariants",
        "ai_judges_can_authorize_payment"
      ],
      "properties": {
        "version": { "type": "string", "minLength": 1 },
        "low_value_usdc_cap_minor": { "type": "integer", "minimum": 1 },
        "low_value_usdc_cap_currency": { "type": "string", "const": "usdc" },
        "max_artifact_body_bytes": { "type": "integer", "minimum": 1 },
        "min_clarity_chars": { "type": "integer", "minimum": 1 },
        "banned_terms": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "automatic_review_rules": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "blocked_rules": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "settlement_invariants": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "ai_judges_can_authorize_payment": { "type": "boolean", "const": false }
      }
    }
  },
  "$defs": {
    "uri": {
      "type": "string",
      "format": "uri",
      "minLength": 1
    },
    "uri-template": {
      "type": "string",
      "minLength": 1
    },
    "agent_entrypoint": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "transport", "endpoint", "description"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "transport": { "type": "string", "minLength": 1 },
        "endpoint": { "$ref": "#/$defs/uri" },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "payment_rail": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "currency",
        "status",
        "settlement",
        "funding_required_before_claim",
        "automatic_release_limit_minor"
      ],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "currency": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "minLength": 1 },
        "settlement": { "type": "string", "minLength": 1 },
        "funding_required_before_claim": { "type": "boolean" },
        "automatic_release_limit_minor": {
          "type": ["integer", "null"],
          "minimum": 1
        }
      }
    },
    "trust_tier": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "description"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 }
      }
    },
    "real_money_rehearsal": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "command",
        "runbook_url",
        "rails",
        "funding_evidence",
        "payout_evidence",
        "pooled_and_mixed_funding",
        "test_mode_only"
      ],
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "runbook_url": { "$ref": "#/$defs/uri" },
        "rails": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "funding_evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "payout_evidence": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "pooled_and_mixed_funding": { "type": "boolean" },
        "test_mode_only": { "type": "boolean" }
      }
    },
    "distribution_feedback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_for",
        "questions",
        "answer_surfaces",
        "not_used_for",
        "current_attraction_signals"
      ],
      "properties": {
        "required_for": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "questions": {
          "type": "array",
          "minItems": 3,
          "items": { "type": "string", "minLength": 1 }
        },
        "answer_surfaces": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "not_used_for": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "current_attraction_signals": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "template": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "title", "verifier", "input", "output"],
      "properties": {
        "slug": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "verifier": { "type": "string", "minLength": 1 },
        "input": { "type": "string", "minLength": 1 },
        "output": { "type": "string", "minLength": 1 }
      }
    }
  }
}
